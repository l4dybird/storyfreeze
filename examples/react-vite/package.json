{
  "name": "storyfreeze-react-vite-fixture",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "clear": "rimraf __screenshots__ storybook-static storybook-static-baseline",
    "storybook": "storybook dev -p 9009 --exact-port --no-open",
    "build-storybook": "storybook build --test",
    "build-storybook:baseline": "storybook build --test --config-dir .storybook-simple -o storybook-static-baseline",
    "storyfreeze:prepare": "node ../../scripts/e2e-prestorybook.js .",
    "storyfreeze:simple-dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --outDir __screenshots__/simple --serverTimeout 30000 --serverCmd \"storybook dev -p 9011 --host 127.0.0.1 --ci --exact-port --no-open --config-dir .storybook-simple\" http://127.0.0.1:9011",
    "storyfreeze:dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --outDir __screenshots__/managed --serverTimeout 30000 --serverCmd \"storybook dev -p 9009 --ci --exact-port --no-open\" http://127.0.0.1:9009",
    "typecheck:preview": "node ../../node_modules/typescript/bin/tsc --allowJs --checkJs --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck .storybook/preview.js",
    "test:preview-protocol": "npm run typecheck:preview && node ../../scripts/storybook-preview-protocol.js ."
  },
  "dependencies": {
    "@fontsource/noto-sans": "5.2.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "rimraf": "6.1.3",
    "storybook": "10.5.0",
    "vite": "7.3.6"
  }
}
