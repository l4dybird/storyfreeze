{
  "name": "storyfreeze",
  "version": "0.1.0-alpha.0",
  "description": "Capture screenshot images from Storybook stories via Puppeteer.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/storybook/preview.d.ts",
      "import": "./dist/storybook/preview.js"
    }
  },
  "sideEffects": [
    "./dist/storybook/preview.js"
  ],
  "bin": {
    "storyfreeze": "dist/node/cli.js"
  },
  "scripts": {
    "clean": "rimraf -g dist lib lib-esm \"*.tsbuildinfo\"",
    "build": "tsc --p tsconfig.build.json",
    "prepare": "npm run clean && npm run build",
    "test": "vp test run --root ../..",
    "typedoc": "typedoc --out \"../../dist-pages/typedoc/storyfreeze\" --ignoreCompilerErrors --tsconfig tsconfig.build.json src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l4dybird/storyfreeze.git"
  },
  "author": "tsuyoshiwada",
  "contributors": [
    "Yosuke Kurami"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/l4dybird/storyfreeze/issues"
  },
  "homepage": "https://github.com/l4dybird/storyfreeze#readme",
  "files": [
    "dist",
    "assets",
    "CONTRIBUTING.md",
    "MIGRATION.md",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "storybook-addon",
    "storybook",
    "addon",
    "puppeteer",
    "chrome",
    "screenshot",
    "capture",
    "visual-testing",
    "testing",
    "test"
  ],
  "devDependencies": {
    "@types/mkdirp": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/wait-on": "^5.0.0",
    "puppeteer": "23.11.1",
    "typedoc": "0.27.6",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "chalk": "^2.4.1",
    "gunshi": "^0.36.0",
    "mkdirp": "^3.0.0",
    "nanomatch": "^1.2.13",
    "puppeteer-core": "^9.0.0",
    "rimraf": "^6.0.0",
    "sanitize-filename": "^1.6.3",
    "wait-on": "^7.0.0"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  }
}
