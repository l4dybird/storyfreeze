{
  "name": "storyfreeze-root",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "changeset:version": "node scripts/prepare-changeset-prerelease.js && changeset version && pnpm --filter storyfreeze build && pnpm doc",
    "clean": "pnpm --filter \"./packages/**\" -r run clean",
    "doc:clihelp": "node scripts/cli-help.js",
    "doc:sync": "node scripts/sync-package-docs.js",
    "doc": "pnpm doc:clihelp && pnpm doc:sync",
    "build": "vp run build:packages && pnpm doc",
    "format": "vp fmt --write \"packages/**/src/**/*\" \"scripts/**/*\" \"*.md\" \"packages/*/*.md\"",
    "format:check": "vp fmt --check \"packages/**/src/**/*\" \"scripts/**/*\"",
    "lint": "vp lint packages/storyfreeze/src",
    "test": "vp run --filter \"./packages/**\" --fail-if-no-match test",
    "package:smoke": "node scripts/package-smoke.js",
    "publish:dry-run": "node scripts/publish-dry-run.js",
    "e2e": "bash e2e.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l4dybird/storyfreeze.git"
  },
  "author": "tsuyoshiwada",
  "contributors": [
    "Yosuke Kurami"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/l4dybird/storyfreeze/issues"
  },
  "homepage": "https://github.com/l4dybird/storyfreeze#readme",
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "gunshi": "^0.36.0",
    "husky": "9.1.7",
    "pngjs": "7.0.0",
    "typescript": "5.7.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "version": "0.0.0"
}
