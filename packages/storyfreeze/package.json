{
  "name": "storyfreeze",
  "version": "0.0.0-development.0",
  "description": "Capture screenshot images from Storybook stories via Puppeteer.",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/client/register.d.ts",
      "import": "./dist/client/register.js"
    }
  },
  "sideEffects": [
    "./dist/client/register.js"
  ],
  "bin": {
    "storyfreeze": "./dist/node/cli.js"
  },
  "scripts": {
    "clean": "rimraf -g dist lib lib-esm \"*.tsbuildinfo\"",
    "build": "tsc --p tsconfig.build.json",
    "prepare": "npm run clean && npm run build",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "typedoc": "typedoc --out \"../../dist-pages/typedoc/storyfreeze\" --ignoreCompilerErrors --tsconfig tsconfig.build.json src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l4dybird/storyfreeze.git"
  },
  "author": "tsuyoshiwada",
  "contributors": [
    "Yosuke Kurami"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/l4dybird/storyfreeze/issues"
  },
  "homepage": "https://github.com/l4dybird/storyfreeze#readme",
  "files": [
    "dist",
    "assets",
    "CONTRIBUTING.md",
    "MIGRATION.md",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "storybook",
    "addon",
    "puppeteer",
    "chrome",
    "screenshot",
    "capture",
    "visual-testing",
    "storybook-addon",
    "testing",
    "test"
  ],
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/mkdirp": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/wait-on": "^5.0.0",
    "@types/yargs": "^17.0.0",
    "jest": "29.7.0",
    "minimist": "1.2.8",
    "puppeteer": "23.11.1",
    "ts-jest": "29.2.5",
    "typedoc": "0.27.6",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "mkdirp": "^3.0.0",
    "nanomatch": "^1.2.13",
    "puppeteer-core": "^9.0.0",
    "rimraf": "^6.0.0",
    "sanitize-filename": "^1.6.3",
    "storycrawler": "^5.0.1",
    "yargs": "^17.0.0"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "diagnostics": false,
          "useESM": true
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/__tests__/*.(ts|tsx)",
      "**/*.test.(ts|tsx)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "_old/.*",
      "examples/.*",
      "\\.d\\.ts$",
      "dist/.*"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost"
    }
  }
}
