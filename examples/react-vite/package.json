{
  "name": "storyfreeze-react-vite-fixture",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clear": "rimraf __screenshots__ storybook-static",
    "storybook": "storybook dev -p 9009 --exact-port --no-open",
    "build-storybook": "npm run build-storybook:managed",
    "build-storybook:simple": "storybook build --test --config-dir .storybook-simple -o storybook-static/simple",
    "build-storybook:managed": "storybook build --test --config-dir .storybook -o storybook-static/managed",
    "storyfreeze:prepare": "node ../../scripts/e2e-prestorybook.js .",
    "storyfreeze:simple-dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/simple-dev --server-timeout 30000 --server-cmd \"storybook dev -p 9011 --host 127.0.0.1 --ci --exact-port --no-open --config-dir .storybook-simple\" http://127.0.0.1:9011",
    "storyfreeze:managed-dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/managed-dev --server-timeout 30000 --server-cmd \"storybook dev -p 9009 --host 127.0.0.1 --ci --exact-port --no-open\" http://127.0.0.1:9009",
    "storyfreeze:simple-static": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/simple-static --server-timeout 30000 --server-cmd \"vite preview --outDir storybook-static/simple --host 127.0.0.1 --port 9012 --strictPort\" http://127.0.0.1:9012",
    "storyfreeze:managed-static": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/managed-static --server-timeout 30000 --server-cmd \"vite preview --outDir storybook-static/managed --host 127.0.0.1 --port 9013 --strictPort\" http://127.0.0.1:9013",
    "storyfreeze:filter-dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/filter-dev --include \"Compatibility/Fixture/**\" --exclude \"Compatibility/Fixture/Console Error\" --exclude \"Compatibility/Fixture/Retry\" --server-timeout 30000 --server-cmd \"storybook dev -p 9014 --host 127.0.0.1 --ci --exact-port --no-open\" http://127.0.0.1:9014",
    "storyfreeze:filter-static": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/filter-static --include \"Compatibility/Fixture/**\" --exclude \"Compatibility/Fixture/Console Error\" --exclude \"Compatibility/Fixture/Retry\" --server-timeout 30000 --server-cmd \"vite preview --outDir storybook-static/managed --host 127.0.0.1 --port 9015 --strictPort\" http://127.0.0.1:9015",
    "storyfreeze:shard-dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/shard-dev --shard 2/2 --server-timeout 30000 --server-cmd \"storybook dev -p 9016 --host 127.0.0.1 --ci --exact-port --no-open\" http://127.0.0.1:9016",
    "storyfreeze:shard-static": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/shard-static --shard 2/2 --server-timeout 30000 --server-cmd \"vite preview --outDir storybook-static/managed --host 127.0.0.1 --port 9017 --strictPort\" http://127.0.0.1:9017",
    "storyfreeze:retry-dev": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/retry-dev --include \"Compatibility/Fixture/Retry\" --capture-timeout 3000 --capture-max-retry-count 1 --server-timeout 30000 --server-cmd \"storybook dev -p 9018 --host 127.0.0.1 --ci --exact-port --no-open\" http://127.0.0.1:9018",
    "storyfreeze:retry-static": "node node_modules/storyfreeze/dist/node/cli.js --verbose --parallel 1 --out-dir __screenshots__/retry-static --include \"Compatibility/Fixture/Retry\" --capture-timeout 3000 --capture-max-retry-count 1 --server-timeout 30000 --server-cmd \"vite preview --outDir storybook-static/managed --host 127.0.0.1 --port 9019 --strictPort\" http://127.0.0.1:9019",
    "typecheck:preview": "node ../../node_modules/typescript/bin/tsc --allowJs --checkJs --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck .storybook/preview.js",
    "test:storybook10-e2e": "npm run typecheck:preview && node ../../scripts/storybook-preview-protocol.js ."
  },
  "dependencies": {
    "@fontsource/noto-sans": "5.2.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "rimraf": "6.1.3",
    "storybook": "10.5.0",
    "vite": "7.3.6"
  }
}
