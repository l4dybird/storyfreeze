{
  "name": "storyfreeze-root",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "changeset:version": "node scripts/prepare-changeset-prerelease.js && changeset version",
    "clean": "pnpm --filter \"./packages/**\" -r run clean",
    "doc:clihelp": "node scripts/cli-help.js",
    "doc:toc": "node scripts/add-toc.js",
    "doc": "pnpm doc:clihelp && pnpm doc:toc && prettier --write \"*.md\" --loglevel warn",
    "typedoc:build": "pnpm --filter \"./packages/**\" -r run typedoc",
    "copy:misc": "pnpm copy:misc:storyfreeze",
    "copy:misc:storyfreeze": "cpy README.md CONTRIBUTING.md MIGRATION.md LICENSE packages/storyfreeze",
    "build": "vp run build:packages && vp run doc && vp run copy:misc",
    "build:pages": "pnpm typedoc:build",
    "format": "prettier --write \"packages/**/src/**/*\" \"scripts/**/*\" \"*.md\" \"packages/*/*.md\"",
    "format:check": "prettier --check \"packages/**/src/**/*\" \"scripts/**/*\"",
    "lint": "vp lint packages/storyfreeze/src",
    "test": "vp run --filter \"./packages/**\" --fail-if-no-match test",
    "package:smoke": "node scripts/package-smoke.js",
    "publish:dry-run": "pnpm --filter \"./packages/**\" -r publish --dry-run --no-git-checks --config.skip-manifest-obfuscation=true --tag next --access public --registry https://registry.npmjs.org/",
    "baseline:verify": "node scripts/validate-baseline.js",
    "e2e": "bash e2e.sh",
    "regression": "reg-suit run",
    "deploy:pages": "gh-pages -d dist-pages -m \"[ci skip]\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l4dybird/storyfreeze.git"
  },
  "author": "tsuyoshiwada",
  "contributors": [
    "Yosuke Kurami"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/l4dybird/storyfreeze/issues"
  },
  "homepage": "https://github.com/l4dybird/storyfreeze#readme",
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "cpy-cli": "5.0.0",
    "gh-pages": "6.3.0",
    "gunshi": "^0.36.0",
    "husky": "9.1.7",
    "markdown-toc": "1.2.0",
    "prettier": "3.4.2",
    "pretty-quick": "4.0.0",
    "reg-keygen-git-hash-plugin": "0.14.3",
    "reg-notify-github-plugin": "0.14.3",
    "reg-publish-s3-plugin": "0.14.3",
    "reg-suit": "0.14.3",
    "typescript": "5.7.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "version": "0.0.0"
}
