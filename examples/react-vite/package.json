{
  "name": "storyfreeze-react-vite-fixture",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clear": "rimraf __screenshots__ storybook-static",
    "storybook": "storybook dev -p 9009 --exact-port --no-open",
    "build-storybook": "pnpm run build-storybook:managed",
    "build-storybook:simple": "storybook build --test --config-dir .storybook-simple -o storybook-static/simple",
    "build-storybook:managed": "storybook build --test --config-dir .storybook -o storybook-static/managed",
    "build-storybook:performance": "storybook build --test --config-dir .storybook-performance -o storybook-static/performance",
    "storyfreeze:simple-static": "storyfreeze --verbose --mode simple --parallel 1 --out-dir __screenshots__/simple-static --server-timeout 30000 --server-cmd \"vite preview --outDir storybook-static/simple --host 127.0.0.1 --port 9012 --strictPort\" http://127.0.0.1:9012",
    "storyfreeze:managed-static": "storyfreeze --verbose --mode managed --browser-isolation context --parallel 4 --out-dir __screenshots__/managed-static http://127.0.0.1:9013",
    "storyfreeze:auto-static": "storyfreeze --verbose --mode managed --browser-isolation hybrid --capture-protocol auto --parallel 4 --out-dir __screenshots__/auto-static --include \"Compatibility/Fixture/Interactions\" http://127.0.0.1:9013",
    "storyfreeze:filter-static": "storyfreeze --verbose --mode managed --parallel 1 --out-dir __screenshots__/filter-static --include \"Compatibility/Fixture/**\" --exclude \"Compatibility/Fixture/Console Error\" --exclude \"Compatibility/Fixture/Retry\" http://127.0.0.1:9013",
    "storyfreeze:shard-static": "storyfreeze --verbose --mode managed --parallel 1 --out-dir __screenshots__/shard-static --shard 2/2 http://127.0.0.1:9013",
    "storyfreeze:retry-static": "storyfreeze --verbose --mode managed --parallel 1 --out-dir __screenshots__/retry-static --include \"Compatibility/Fixture/Retry\" --capture-timeout 3000 --capture-max-retry-count 1 http://127.0.0.1:9013",
    "benchmark:roadmap": "node ../../scripts/performance-roadmap-benchmark.js .",
    "typecheck:preview": "tsc --allowJs --checkJs --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck .storybook/preview.js",
    "test:storybook10-e2e": "pnpm run typecheck:preview && node ../../scripts/e2e-prestorybook.js ."
  },
  "dependencies": {
    "@fontsource/noto-sans": "5.2.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "rimraf": "6.1.3",
    "storybook": "10.5.2",
    "typescript": "5.7.3",
    "vite": "7.3.6"
  }
}
